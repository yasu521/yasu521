name: Delete old workflow runs
on:
  schedule:
    - cron: "0 0 * * *" # 毎日 UTC 00:00 (日本時間の午前9時) に実行
  workflow_dispatch:
jobs:
  delete-runs:
    runs-on: ubuntu-latest
    permissions:
      actions: write
      contents: read
    steps:
      - name: Delete workflow runs
        uses: Mattraks/delete-workflow-runs@v2
        with:
          token: ${{ github.token }}
          repository: ${{ github.repository }}
          retain_days: 3
          keep_minimum_runs: 3
